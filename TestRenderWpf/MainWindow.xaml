<Window x:Class="TestRenderWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestRenderWpf" WindowStartupLocation="CenterScreen"
        xmlns:scrcpy="clr-namespace:TqkLibrary.Scrcpy.Wpf;assembly=TqkLibrary.Scrcpy.Wpf"
        xmlns:st="http://schemas.spicytaco.io/"
        mc:Ignorable="d" Loaded="Window_Loaded" Unloaded="Window_Unloaded" Closed="Window_Closed"
        Title="MainWindow" Height="600" Width="1000">
    <Window.DataContext>
        <local:MainWindowVM/>
    </Window.DataContext>
    <st:StackPanel Background="Black" Orientation="Horizontal" MarginBetweenChildren="5">
        <st:StackPanel Grid.Column="0" Orientation="Vertical" MarginBetweenChildren="5" Margin="5,0,0,0">
            <Button Content="InjectText Clipboard" Command="{Binding InjectTextCommand}"/>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <CheckBox Content="DisplayPower" IsChecked="{Binding DisplayPower}" VerticalAlignment="Center" Foreground="White"/>
            </StackPanel>
            <st:StackPanel Grid.Column="0" Orientation="Horizontal" MarginBetweenChildren="5">
                <Button Content="BackOrScreenOn" Command="{Binding BackOrScreenOnCommand}"/>
                <ComboBox ItemsSource="{Binding AndroidKeyEventActions}" SelectedItem="{Binding AndroidKeyEventActionSelected}"/>
            </st:StackPanel>
            <Button Content="ExpandNotificationPanel" Command="{Binding ExpandNotificationPanelCommand}"/>
            <Button Content="ExpandSettingsPanel" Command="{Binding ExpandSettingsPanelCommand}"/>
            <Button Content="CollapsePanel" Command="{Binding CollapsePanelCommand}"/>
            <Button Content="RotateDevice" Command="{Binding RotateDeviceCommand}"/>
            <Button Content="OpenHardKeyboardSetting" Command="{Binding OpenHardKeyboardSettingCommand}"/>
        </st:StackPanel>
        <scrcpy:ScrcpyControl st:StackPanel.Fill="Fill"
                              IsControl="{Binding IsControl}" 
                              Control="{Binding Control}" 
                              ScrcpyUiView="{Binding ScrcpyUiView}"
                              IsMouseHandler="True"
                              IsKeyHandler="True"
                              />
    </st:StackPanel>
</Window>
